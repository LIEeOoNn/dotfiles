{
    "editor.fontSize": 14,
    "editor.fontFamily": "'MesloLGS Nerd Font Mono'",
    "editor.fontWeight": "bold",
    "editor.fontLigatures": false,
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.fontFamily": "MesloLGS Nerd Font Mono",
    "terminal.integrated.fontWeight": "bold",
    "security.workspace.trust.untrustedFiles": "open",
    "files.autoSave": "afterDelay",
    "editor.minimap.enabled": false,
    "workbench.iconTheme": "vscode-icons",
    "r.rpath.mac": "/Users/leon/miniconda3/envs/r_env/bin/R",
     "r.rterm.mac": "/Users/leon/miniconda3/envs/r_env/bin/R",
    "explorer.confirmDelete": false,
    "python.analysis.typeCheckingMode": "standard",
    "workbench.colorTheme": "Visual Studio 2017 Dark - C++",
    "explorer.confirmDragAndDrop": false,
    "vsicons.dontShowNewVersionMessage": true,
    "github.copilot.nextEditSuggestions.enabled": true,
    "markdown.extension.preview.autoShowPreviewToSide": true,
    "chat.viewProgressBadge.enabled": true,
    "markdown-preview-enhanced.enablePreviewZenMode": true,
    "markdown-preview-enhanced.previewTheme": "monokai.css",
    "chat.plugins.marketplaces": [
        "github/copilot-plugins",
        "github/awesome-copilot",
        "https://github.com/juliusbrussee/caveman"
    ],
    "notebook.lineNumbers": "on",
    "jupyter.askForKernelRestart": false,
    "python.createEnvironment.trigger": "off",
    "vim.enableNeovim": true,
    "vim.neovimUseConfigFile": true,
    "vim.neovimPath": "/opt/homebrew/bin/nvim",
    "vim.neovimConfigPath": "~/.config/nvim/init.lua",
    "vim.useSystemClipboard": true,
    "chat.viewSessions.orientation": "stacked",
}
